{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Adomi Odoo chart values",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "global": { "type": "object" },

    "replicaCount": { "type": "integer", "minimum": 0 },

    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string" },
        "pullPolicy": { "type": "string", "enum": ["Always", "Never", "IfNotPresent"] }
      }
    },

    "imagePullSecrets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": { "name": { "type": "string" } }
      }
    },

    "nameOverride": { "type": "string", "maxLength": 63 },
    "fullnameOverride": { "type": "string", "maxLength": 63 },

    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create": { "type": "boolean" },
        "annotations": { "type": "object" },
        "name": { "type": "string" }
      }
    },

    "podAnnotations": { "type": "object" },
    "podLabels": { "type": "object" },
    "podSecurityContext": { "type": "object" },
    "securityContext": { "type": "object" },

    "service": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer", "ExternalName"] },
        "httpPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "longpollingPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "annotations": { "type": "object" }
      }
    },

    "ingress": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": { "type": "object" },
        "hosts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["host"],
            "properties": {
              "host": { "type": "string", "minLength": 1 },
              "paths": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["path"],
                  "properties": {
                    "path": { "type": "string", "minLength": 1 },
                    "pathType": { "type": "string", "enum": ["Exact", "Prefix", "ImplementationSpecific"] }
                  }
                }
              }
            }
          }
        },
        "longpolling": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "paths": { "type": "array", "items": { "type": "string" } }
          }
        },
        "tls": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "secretName": { "type": "string" },
              "hosts": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },

    "resources": { "type": "object" },

    "autoscaling": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 },
        "targetCPUUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 },
        "targetMemoryUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 }
      }
    },

    "persistence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "mountPath": { "type": "string", "minLength": 1 },
        "storageClass": { "type": "string" },
        "accessModes": {
          "type": "array",
          "items": { "type": "string", "enum": ["ReadWriteOnce", "ReadOnlyMany", "ReadWriteMany", "ReadWriteOncePod"] }
        },
        "size": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?(m|k|M|G|T|P|E|Ki|Mi|Gi|Ti|Pi|Ei)?$" },
        "existingClaim": { "type": "string" },
        "annotations": { "type": "object" }
      }
    },

    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array" },
    "affinity": { "type": "object" },
    "topologySpreadConstraints": { "type": "array" },

    "livenessProbe": { "type": "object" },
    "readinessProbe": { "type": "object" },
    "startupProbe": { "type": "object" },

    "adminPassword": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "value": { "type": "string" },
        "existingSecret": { "type": "string" },
        "existingSecretKey": { "type": "string" }
      },
      "if": {
        "properties": { "existingSecret": { "type": "string", "minLength": 1 } },
        "required": ["existingSecret"]
      },
      "then": {
        "properties": { "existingSecretKey": { "type": "string", "minLength": 1 } },
        "required": ["existingSecretKey"]
      }
    },

    "database": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "host": { "type": "string" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "name": { "type": "string", "minLength": 1 },
        "user": { "type": "string", "minLength": 1 },
        "password": { "type": "string" },
        "sslmode": { "type": "string", "enum": ["disable", "allow", "prefer", "require", "verify-ca", "verify-full"] },
        "existingSecret": { "type": "string" },
        "existingSecretKey": { "type": "string" }
      },
      "if": {
        "properties": { "existingSecret": { "type": "string", "minLength": 1 } },
        "required": ["existingSecret"]
      },
      "then": {
        "properties": { "existingSecretKey": { "type": "string", "minLength": 1 } },
        "required": ["existingSecretKey"]
      }
    },

    "odoo": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "workers": { "type": "integer", "minimum": 0 },
        "proxyMode": { "type": "boolean" },
        "listDb": { "type": "boolean" },
        "logLevel": { "type": "string" },
        "withoutDemo": { "type": "boolean" },
        "loadLanguage": { "type": "string" },
        "initModules": { "type": "string" },
        "updateModules": { "type": "string" }
      }
    },

    "extraEnv": { "type": "array" },
    "extraEnvFrom": { "type": "array" },
    "odooConf": { "type": "string" },
    "extraVolumes": { "type": "array" },
    "extraVolumeMounts": { "type": "array" },

    "postgresql": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "image": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "tag": { "type": "string" },
            "pullPolicy": { "type": "string", "enum": ["Always", "Never", "IfNotPresent"] }
          }
        },
        "podSecurityContext": { "type": "object" },
        "securityContext": { "type": "object" },
        "persistence": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "storageClass": { "type": "string" },
            "accessModes": {
              "type": "array",
              "items": { "type": "string", "enum": ["ReadWriteOnce", "ReadOnlyMany", "ReadWriteMany", "ReadWriteOncePod"] }
            },
            "size": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?(m|k|M|G|T|P|E|Ki|Mi|Gi|Ti|Pi|Ei)?$" }
          }
        },
        "resources": { "type": "object" },
        "nodeSelector": { "type": "object" },
        "tolerations": { "type": "array" },
        "affinity": { "type": "object" }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "required": ["postgresql"],
        "properties": {
          "postgresql": {
            "required": ["enabled"],
            "properties": { "enabled": { "const": false } }
          }
        }
      },
      "then": {
        "properties": {
          "database": {
            "required": ["host"],
            "properties": { "host": { "type": "string", "minLength": 1 } }
          }
        },
        "required": ["database"]
      }
    }
  ]
}
